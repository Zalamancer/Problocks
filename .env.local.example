# ─── Google OAuth (Google Cloud Console) ─────────────────────────────────────
# 1. Go to console.cloud.google.com → APIs & Services → Credentials
# 2. Create an OAuth 2.0 Client ID (Web Application)
# 3. Add Authorized redirect URI: http://localhost:3002/api/auth/callback/google
# 4. Enable "Google Classroom API" in the API library

GOOGLE_CLIENT_ID=your-google-client-id-here.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your-google-client-secret-here

# ─── NextAuth ─────────────────────────────────────────────────────────────────
# Generate with: openssl rand -base64 32
NEXTAUTH_SECRET=your-nextauth-secret-here
NEXTAUTH_URL=http://localhost:3002

# ─── Anthropic ────────────────────────────────────────────────────────────────
ANTHROPIC_API_KEY=your-anthropic-api-key-here

# ─── Supabase ─────────────────────────────────────────────────────────────────
# 1. Go to supabase.com → Create a project (or use existing)
# 2. Go to Settings → API → copy Project URL and anon/public key
# 3. Create a Storage bucket named "games" (public)
# 4. Run the migration in supabase/migrations/001_create_games_table.sql

NEXT_PUBLIC_SUPABASE_URL=https://your-project-id.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-supabase-anon-key-here

# Service role key — server-only. Used by admin routes (moderation queue,
# data-request admin surface) to bypass RLS. Get it from Settings → API →
# "service_role" secret. NEVER prefix this with NEXT_PUBLIC_; it grants
# full database access.
SUPABASE_SERVICE_ROLE_KEY=your-supabase-service-role-key-here

# ─── Admin bootstrap ──────────────────────────────────────────────────────────
# Comma-separated list of email addresses that get auto-promoted to
# role='admin' the first time they sign in with Google. Solves the
# chicken-and-egg of "/admin/teachers requires an admin to promote, but
# nobody is admin yet."
#
# Keep this list short — typically just the founders / on-call ops. Admin
# role unlocks data_requests, moderation queue, teacher promotion, audit
# log, etc. The bootstrap ONLY promotes; it never demotes (so removing an
# email from this list doesn't take someone's admin role away — that has
# to be done manually via /admin/teachers or the Supabase dashboard).
ADMIN_BOOTSTRAP_EMAILS=
